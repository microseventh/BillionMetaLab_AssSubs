Dialogue: 0,0:04:56.77,0:04:58.94,CN-op,,0,0,0,,{\fad(240,0)\fs42\pos(963.2,795.2)\blur4\c&HA24CEC&}BILLION META LAB\NMICROSEVENTH
Comment: 0,0:03:28.56,0:03:29.56,jp-op,,0,0,0,,出现标
Dialogue: 0,0:03:29.56,0:03:32.44,jp-op,,0,0,0,,咲き誇れ今　咲き誇れ今
Dialogue: 0,0:03:32.44,0:03:35.61,jp-op,,0,0,0,,最果てまで君となら行けるよ
Dialogue: 0,0:03:35.61,0:03:37.90,jp-op,,0,0,0,,勇敢に咲いた花よ
Dialogue: 0,0:03:37.90,0:03:39.36,jp-op,,0,0,0,,ほらまた
Dialogue: 0,0:03:40.57,0:03:43.66,jp-op,,0,0,0,,ほらまた　出会えるから
Dialogue: 0,0:03:49.58,0:03:52.87,jp-op,,0,0,0,,浮かんだ世界　迷い込んだみたい
Dialogue: 0,0:03:54.75,0:03:58.34,jp-op,,0,0,0,,私らしい強さ　いつも探してた
Dialogue: 0,0:03:59.96,0:04:02.80,jp-op,,0,0,0,,お気に入りの私でいたい
Dialogue: 0,0:04:02.80,0:04:05.51,jp-op,,0,0,0,,たったそれだけなのにな
Dialogue: 0,0:04:05.51,0:04:10.02,jp-op,,0,0,0,,ずっと何かと戦い続けてる日々です
Dialogue: 0,0:04:10.85,0:04:13.52,jp-op,,0,0,0,,少し進むたび転んだ
Dialogue: 0,0:04:13.52,0:04:16.36,jp-op,,0,0,0,,傷だらけの膝のまま
Dialogue: 0,0:04:16.36,0:04:19.23,jp-op,,0,0,0,,立ち上がるんだそう
Dialogue: 0,0:04:19.23,0:04:21.15,jp-op,,0,0,0,,一人じゃないってこと
Dialogue: 0,0:04:21.65,0:04:24.66,jp-op,,0,0,0,,咲き誇れ今　咲き誇れ今
Dialogue: 0,0:04:24.66,0:04:27.87,jp-op,,0,0,0,,最果てまで君となら行けるよ
Dialogue: 0,0:04:27.87,0:04:32.83,jp-op,,0,0,0,,永遠よりもきらり　眩しく光るこの瞬間
Dialogue: 0,0:04:32.83,0:04:35.38,jp-op,,0,0,0,,舞い上がれ今　舞い上がれ今
Dialogue: 0,0:04:35.38,0:04:38.75,jp-op,,0,0,0,,いつか訪れる終わりなど無視して
Dialogue: 0,0:04:38.75,0:04:40.76,jp-op,,0,0,0,,勇敢に咲いた花よ
Dialogue: 0,0:04:40.76,0:04:46.39,jp-op,,0,0,0,,ほらまた　出会えるから
Dialogue: 0,0:04:46.39,0:04:51.85,jp-op,,0,0,0,,らららららら　この瞳
Dialogue: 0,0:04:51.85,0:04:58.94,jp-op,,0,0,0,,らららららら　百日経っても忘れないで
Comment: 0,0:03:29.06,0:03:29.56,CN-op,,0,0,0,,出現標
Dialogue: 0,0:03:29.56,0:03:32.44,CN-op,,0,0,0,,正是現在　花開怒放
Dialogue: 0,0:03:32.44,0:03:35.61,CN-op,,0,0,0,,有你相伴　走馬天涯
Dialogue: 0,0:03:35.61,0:03:37.90,CN-op,,0,0,0,,勇敢綻放的花兒喲
Dialogue: 0,0:03:37.90,0:03:39.36,CN-op,,0,0,0,,莫要擔心
Dialogue: 0,0:03:40.57,0:03:43.66,CN-op,,0,0,0,,莫要害怕　比鄰天涯
Dialogue: 0,0:03:49.58,0:03:52.87,CN-op,,0,0,0,,浮沉世界　如墮煙海
Dialogue: 0,0:03:54.75,0:03:58.34,CN-op,,0,0,0,,一直尋覓　堅毅自強
Dialogue: 0,0:03:59.96,0:04:02.80,CN-op,,0,0,0,,成為我想
Dialogue: 0,0:04:02.80,0:04:05.51,CN-op,,0,0,0,,簡單明瞭
Dialogue: 0,0:04:05.51,0:04:10.02,CN-op,,0,0,0,,奮鬥掙扎　每分每秒
Dialogue: 0,0:04:10.85,0:04:13.52,CN-op,,0,0,0,,每進一步　就會跌倒
Dialogue: 0,0:04:13.52,0:04:16.36,CN-op,,0,0,0,,傷痕累累　膝蓋結痂
Dialogue: 0,0:04:16.36,0:04:19.23,CN-op,,0,0,0,,但我依舊　起身昂揚
Dialogue: 0,0:04:19.23,0:04:21.15,CN-op,,0,0,0,,因為我曉　有依有靠
Dialogue: 0,0:04:21.65,0:04:24.66,CN-op,,0,0,0,,花開怒放　此刻正好
Dialogue: 0,0:04:24.66,0:04:27.87,CN-op,,0,0,0,,與你同在　踏馬尋花
Dialogue: 0,0:04:27.87,0:04:32.83,CN-op,,0,0,0,,永恆雖美　此刻更好
Dialogue: 0,0:04:32.83,0:04:35.38,CN-op,,0,0,0,,起舞弄影　正值當下
Dialogue: 0,0:04:35.38,0:04:38.75,CN-op,,0,0,0,,莫懼終末　總會來到
Dialogue: 0,0:04:38.75,0:04:40.76,CN-op,,0,0,0,,勇敢綻放的花兒喲
Dialogue: 0,0:04:40.76,0:04:46.39,CN-op,,0,0,0,,無需害怕　咫尺天涯
Dialogue: 0,0:04:46.39,0:04:51.85,CN-op,,0,0,0,,啦啦啦啦　這雙眼眸
Dialogue: 0,0:04:51.85,0:04:58.94,CN-op,,0,0,0,,啦啦啦啦　銘心不忘
Comment: 0,0:21:21.09,0:21:21.38,jp-ed-235,,0,0,0,,ED-JP
Dialogue: 0,0:21:21.38,0:21:25.76,jp-ed-235,,0,0,0,,タイムマシンがあったなら
Dialogue: 0,0:21:25.76,0:21:31.39,jp-ed-235,,0,0,0,,どこに行きなにをだれとするだろう
Dialogue: 0,0:21:36.94,0:21:41.57,jp-ed-235,,0,0,0,,たとえば、きのう
Dialogue: 0,0:21:41.57,0:21:46.07,jp-ed-235,,0,0,0,,「一緒に帰ろ」って言えなかった
Dialogue: 0,0:21:46.07,0:21:53.91,jp-ed-235,,0,0,0,,私の背中を隠れて、さりげなくね
Dialogue: 0,0:21:53.91,0:21:58.84,jp-ed-235,,0,0,0,,そっと押せるかな　スイッチバック
Dialogue: 0,0:21:58.84,0:22:01.13,jp-ed-235,,0,0,0,,夏空、ラムネと蝉時雨
Dialogue: 0,0:22:01.13,0:22:03.76,jp-ed-235,,0,0,0,,電車出発まで後少しだね
Dialogue: 0,0:22:03.76,0:22:05.76,jp-ed-235,,0,0,0,,嫌がられたらどうしよ
Dialogue: 0,0:22:05.76,0:22:08.39,jp-ed-235,,0,0,0,,でも、それより後悔が怖いよ
Dialogue: 0,0:22:08.39,0:22:09.05,jp-ed-235,,0,0,0,,そっか
Dialogue: 0,0:22:09.05,0:22:11.64,jp-ed-235,,0,0,0,,上手くいかなくたってもう一回
Dialogue: 0,0:22:11.64,0:22:13.81,jp-ed-235,,0,0,0,,胸を張って挑めばいい
Dialogue: 0,0:22:13.81,0:22:17.69,jp-ed-235,,0,0,0,,そうやって生きていこうよ
Dialogue: 0,0:22:17.69,0:22:21.61,jp-ed-235,,0,0,0,,思い出は消えない　褪せない
Dialogue: 0,0:22:21.61,0:22:28.11,jp-ed-235,,0,0,0,,また明日って笑い合い　ゆびきりしたなら
Dialogue: 0,0:22:28.11,0:22:32.04,jp-ed-235,,0,0,0,,離れてもずっと　そうずっと
Dialogue: 0,0:22:32.04,0:22:34.62,jp-ed-235,,0,0,0,,つながっているだなんて
Dialogue: 0,0:22:34.62,0:22:38.79,jp-ed-235,,0,0,0,,信じてもいいかな
Dialogue: 0,0:22:38.79,0:22:40.67,jp-ed-235,,0,0,0,,二度目の春
Dialogue: 0,0:22:40.67,0:22:44.92,jp-ed-235,,0,0,0,,タイムマシンから降りて　さあ
Dialogue: 0,0:22:44.92,0:22:51.10,jp-ed-235,,0,0,0,,いま、未来の話も、君としよう
Comment: 0,0:21:21.09,0:21:21.38,CN-ed-235,,0,0,0,,ED-CN
Dialogue: 0,0:21:21.38,0:21:25.76,CN-ed-235,,0,0,0,,若是擁有時光機的話
Dialogue: 0,0:21:25.76,0:21:31.39,CN-ed-235,,0,0,0,,會和誰在一起去逍遙遊呢
Dialogue: 0,0:21:36.94,0:21:41.57,CN-ed-235,,0,0,0,,例如說 昨天的她
Dialogue: 0,0:21:41.57,0:21:46.07,CN-ed-235,,0,0,0,,沒有說出口的「一起回家」
Dialogue: 0,0:21:46.07,0:21:53.91,CN-ed-235,,0,0,0,,若是有人無心插柳
Dialogue: 0,0:21:53.91,0:21:58.84,CN-ed-235,,0,0,0,,推我一把就好了　就像列車換軌的閘
Dialogue: 0,0:21:58.84,0:22:01.13,CN-ed-235,,0,0,0,,夏日清空 彈珠汽水 蟬鳴驟雨
Dialogue: 0,0:22:01.13,0:22:03.76,CN-ed-235,,0,0,0,,離出發的電車還差幾點
Dialogue: 0,0:22:03.76,0:22:05.76,CN-ed-235,,0,0,0,,要被是討厭的話該怎麼辦呢
Dialogue: 0,0:22:05.76,0:22:08.39,CN-ed-235,,0,0,0,,不過 比起拒絕 後悔我更加害怕
Dialogue: 0,0:22:08.39,0:22:09.05,CN-ed-235,,0,0,0,,是呀
Dialogue: 0,0:22:09.05,0:22:11.64,CN-ed-235,,0,0,0,,就算不順利也不過再來一次
Dialogue: 0,0:22:11.64,0:22:13.81,CN-ed-235,,0,0,0,,挺起胸膛盡情挑戰
Dialogue: 0,0:22:13.81,0:22:17.69,CN-ed-235,,0,0,0,,就這樣好生幸福吧
Dialogue: 0,0:22:17.69,0:22:21.61,CN-ed-235,,0,0,0,,永不消亡褪色的絕對記憶
Dialogue: 0,0:22:21.61,0:22:28.11,CN-ed-235,,0,0,0,,約好了明天見 開心地勾勾小指畫押
Dialogue: 0,0:22:28.11,0:22:32.04,CN-ed-235,,0,0,0,,即便兩線交錯 也依舊有約
Dialogue: 0,0:22:32.04,0:22:34.62,CN-ed-235,,0,0,0,,仍緊緊相連
Dialogue: 0,0:22:34.62,0:22:38.79,CN-ed-235,,0,0,0,,我是能還相信的吧
Dialogue: 0,0:22:38.79,0:22:40.67,CN-ed-235,,0,0,0,,在第二個春天裡
Dialogue: 0,0:22:40.67,0:22:44.92,CN-ed-235,,0,0,0,,從時光機中走出來吧
Dialogue: 0,0:22:44.92,0:22:51.10,CN-ed-235,,0,0,0,,{\an8}現在聊聊 未來以及你我瑣事吧
Comment: 1,0:00:36.41,0:00:38.41,jp,,0,0,0,,OP前
Dialogue: 1,0:00:38.41,0:00:38.93,jp,Anzu,0,0,0,,はい
Dialogue: 1,0:01:15.09,0:01:17.37,jp,Mai,0,0,0,,でた
Dialogue: 1,0:01:21.34,0:01:24.06,jp,Natsume,0,0,0,,何もかも変わるね　これから
Dialogue: 1,0:01:25.14,0:01:27.85,jp,Natsume,0,0,0,,庇護を受けなくても立てるようになるよ
Dialogue: 1,0:01:27.85,0:01:29.78,jp,Natsume,0,0,0,,きっと　この国は
Dialogue: 1,0:01:31.73,0:01:36.42,jp,Suguri,0,0,0,,神の遣いなのでしょうか　あの方々は
Dialogue: 1,0:01:37.66,0:01:39.84,jp,Natsume,0,0,0,,すまなかったね　傑里
Dialogue: 1,0:01:41.47,0:01:43.83,jp,Natsume,0,0,0,,1人では荷が重すぎたよね
Dialogue: 1,0:01:44.33,0:01:47.71,jp,Natsume,0,0,0,,戦に出て　国を守って
Dialogue: 1,0:01:47.71,0:01:50.38,jp,Natsume,0,0,0,,家を　妹たちを
Dialogue: 1,0:01:51.27,0:01:53.38,jp,Natsume,0,0,0,,坂城様に頭を下げて
Dialogue: 1,0:01:55.76,0:01:57.00,jp,Suguri,0,0,0,,悔しいな
Dialogue: 1,0:01:57.88,0:02:02.25,jp,Suguri,0,0,0,,軽々と見えるよう　振る舞っていたつもりでしたので
Dialogue: 1,0:02:03.05,0:02:05.29,jp,Suguri,0,0,0,,でも　だめですね
Dialogue: 1,0:02:06.07,0:02:10.48,jp,Suguri,0,0,0,,姉上のお顔を見た途端　舞い上がってしまいました
Dialogue: 1,0:02:07.78,0:02:10.14,jp - up,Sumomo,0,0,0,,お姉様
Dialogue: 1,0:02:10.14,0:02:13.65,jp - up,Mai,0,0,0,,おい　温泉湧いたよ
Dialogue: 1,0:02:10.49,0:02:12.99,jp,Suguri,0,0,0,,これで全て丸く収まる
Dialogue: 1,0:02:14.57,0:02:18.82,jp,Suguri,0,0,0,,夏夢姉様が坂城様にお輿入れ下されば　と
Dialogue: 1,0:02:20.31,0:02:23.11,jp,Natsume,0,0,0,,そうだよね　ごめん
Dialogue: 1,0:02:23.59,0:02:27.17,jp,Suguri,0,0,0,,いえ　恥ずかしいんです　私は
Dialogue: 1,0:02:28.85,0:02:29.67,jp,Natsume,0,0,0,,何が
Dialogue: 1,0:02:30.46,0:02:35.49,jp,Suguri,0,0,0,,自由でいたい　そんな夏夢姉様のお心は存じていたのに
Dialogue: 1,0:02:35.87,0:02:40.79,jp,Suguri,0,0,0,,己の都合に閉じ込めようとしてしまった　浅ましい心が
Dialogue: 1,0:02:42.73,0:02:45.07,jp,Suguri,0,0,0,,お許しください　姉上
Dialogue: 1,0:02:46.10,0:02:48.25,jp,Natsume,0,0,0,,さすが我らが父上
Dialogue: 1,0:02:48.59,0:02:49.19,jp,Suguri,0,0,0,,え
Dialogue: 1,0:02:49.19,0:02:52.77,jp,Natsume,0,0,0,,見抜いていたんだね　幼い君から
Dialogue: 1,0:02:52.77,0:02:54.87,jp,Natsume,0,0,0,,一国の主の器を
Dialogue: 1,0:02:55.70,0:02:58.66,jp,Suguri,0,0,0,,ええ　そ　そんな　滅相もない
Dialogue: 1,0:02:58.66,0:03:01.45,jp,Natsume,0,0,0,,でもね傑里　忘れないで
Dialogue: 1,0:03:01.45,0:03:03.70,jp,Natsume,0,0,0,,君も自由だってこと
Dialogue: 1,0:03:04.22,0:03:09.35,jp,Natsume,0,0,0,,私は自由でいたいけど　君を1人にする気はないってこと
Dialogue: 1,0:03:09.35,0:03:10.71,jp,Suguri,0,0,0,,姉上
Dialogue: 1,0:03:11.67,0:03:14.29,jp,Natsume,0,0,0,,君だけに背負わせたりしない
Dialogue: 1,0:03:14.29,0:03:17.75,jp,Natsume,0,0,0,,国も　家も　妹たちも
Dialogue: 1,0:03:19.11,0:03:20.47,jp,Natsume,0,0,0,,それから
Dialogue: 1,0:03:22.50,0:03:26.72,jp,Natsume,0,0,0,,この家の愛しい　秘密も
Comment: 1,0:05:00.78,0:05:02.78,jp,,0,0,0,,正文
Dialogue: 1,0:05:02.78,0:05:04.75,jp,Mai,0,0,0,,溶ける
Dialogue: 1,0:05:04.75,0:05:06.70,jp,Sayuri,0,0,0,,溶けるね
Dialogue: 1,0:05:06.70,0:05:08.45,jp,Nozomi,0,0,0,,メルティー
Dialogue: 1,0:05:08.45,0:05:10.45,jp,Nanase,0,0,0,,ウィマダーム
Dialogue: 1,0:05:10.45,0:05:12.35,jp,Rina,0,0,0,,溶けて消滅
Dialogue: 1,0:05:13.85,0:05:17.14,jp,Rina,0,0,0,,しないといいけど　歴史変えちゃって
Dialogue: 1,0:05:18.21,0:05:21.09,jp,Nozomi,0,0,0,,あんた夏休み中に逐一
Dialogue: 1,0:05:21.09,0:05:24.43,jp,Nozomi,0,0,0,,「宿題終わった」って聞いてくるタイプでしょ
Dialogue: 1,0:05:24.43,0:05:25.97,jp,Rina,0,0,0,,意味わからない
Dialogue: 1,0:05:25.97,0:05:30.41,jp,Mai,0,0,0,,ままま　消滅についてはさ　しちゃったらその時考えよ
Dialogue: 1,0:05:30.41,0:05:32.07,jp,Sayuri,0,0,0,,そうだね
Dialogue: 1,0:05:32.07,0:05:34.11,jp,Rina,0,0,0,,消滅したら考えられない
Dialogue: 1,0:05:34.95,0:05:37.65,jp,Nozomi,0,0,0,,てかさ　正直　意外だったわ
Dialogue: 1,0:05:37.65,0:05:41.95,jp,Nozomi,0,0,0,,あんた絶対反対すると思ってた　温泉掘るとか
Dialogue: 1,0:05:41.95,0:05:43.49,jp,Nanase,0,0,0,,それは
Dialogue: 1,0:05:43.49,0:05:46.89,jp,Nanase,0,0,0,,止むに止まれぬと言いますか
Dialogue: 1,0:05:47.24,0:05:50.45,jp,Mai,0,0,0,,取りたくなったんだよね　ガターからスペア
Dialogue: 1,0:05:50.45,0:05:51.66,jp,Rina,0,0,0,,意味わからない
Dialogue: 1,0:05:51.66,0:05:52.99,jp,Mai,0,0,0,,えっ　なんで
Dialogue: 1,0:05:53.22,0:05:56.15,jp,Nanase,0,0,0,,そういえば　何だったんですか　それ
Dialogue: 1,0:05:56.15,0:05:56.75,jp,Mai,0,0,0,,え
Dialogue: 1,0:05:56.75,0:05:59.65,jp,Nanase,0,0,0,,寿桃さんが　ガターとかなんとか
Dialogue: 1,0:05:59.65,0:06:02.13,jp,Mai,0,0,0,,あ　うん
Dialogue: 1,0:06:02.13,0:06:04.55,jp,Mai,0,0,0,,言ってたんだよね　寿桃ちゃん
Dialogue: 1,0:06:04.55,0:06:07.26,jp,Mai,0,0,0,,お馬が来ないのは自分のせいだって
Dialogue: 1,0:06:07.77,0:06:10.63,jp,Mai,0,0,0,,なんかね　バチが当たったって
Dialogue: 1,0:06:10.63,0:06:11.66,jp,Nanase,0,0,0,,バチ
Dialogue: 1,0:06:11.66,0:06:13.76,jp,Mai,0,0,0,,外に出たからって
Dialogue: 1,0:06:14.46,0:06:16.11,jp,Mai,0,0,0,,えっ　どゆこと
Dialogue: 1,0:06:16.77,0:06:23.02,jp,Sumomo,0,0,0,,外に出て　人と出会って　楽しいことして　私だけ
Dialogue: 1,0:06:23.02,0:06:24.46,jp,Mai,0,0,0,,私だけ
Dialogue: 1,0:06:24.46,0:06:26.03,jp,Sumomo,0,0,0,,なんでもない
Dialogue: 1,0:06:26.03,0:06:27.81,jp,Sumomo,0,0,0,,この話　おしまい
Dialogue: 1,0:06:28.19,0:06:29.03,jp,Mai,0,0,0,,って
Dialogue: 1,0:06:29.25,0:06:32.82,jp,Nozomi,0,0,0,,何それ　1ミクロンも関係なくないそんなの
Dialogue: 1,0:06:32.82,0:06:35.42,jp,Mai,0,0,0,,でしょ　ガターだよね　完全に
Dialogue: 1,0:06:35.42,0:06:36.79,jp,Nozomi,0,0,0,,いや　それは
Dialogue: 1,0:06:36.79,0:06:38.28,jp,Rina,0,0,0,,意味わからない
Dialogue: 1,0:06:38.28,0:06:39.94,jp,Sayuri,0,0,0,,うんっ　ガターだね
Dialogue: 1,0:06:39.94,0:06:40.90,jp,Rina,0,0,0,,通じてる
Dialogue: 1,0:06:40.90,0:06:42.79,jp,Nozomi,0,0,0,,ってか　めっちゃ響いてる
Dialogue: 1,0:06:43.77,0:06:45.49,jp,Mai,0,0,0,,七瀬どした
Dialogue: 1,0:06:45.49,0:06:47.42,jp,Nanase,0,0,0,,あっ　いえ
Dialogue: 1,0:06:49.05,0:06:50.80,jp,Nanase,0,0,0,,のぼせてきたんで上がります
Dialogue: 1,0:07:01.54,0:07:02.93,jp,Suguri,0,0,0,,おかえりなさいませ
Dialogue: 1,0:07:03.27,0:07:05.53,jp,Sayuri,0,0,0,,ごめんなさい　邪魔して
Dialogue: 1,0:07:05.53,0:07:08.40,jp,Suguri,0,0,0,,いえ　いい湯でしたか
Dialogue: 1,0:07:08.40,0:07:10.32,jp,Sayuri,0,0,0,,はい　あの
Dialogue: 1,0:07:10.32,0:07:13.60,jp,Sayuri,0,0,0,,作ってもらったんです　1人用のお風呂
Dialogue: 1,0:07:13.60,0:07:14.08,jp,Suguri,0,0,0,,えっ
Dialogue: 1,0:07:14.08,0:07:17.14,jp,Sayuri,0,0,0,,だから入れますよ　傑里さんも
Dialogue: 1,0:07:18.61,0:07:20.04,jp,Suguri,0,0,0,,ありがとうございます
Dialogue: 1,0:07:20.97,0:07:23.04,jp,Sayuri,0,0,0,,あっ　そういえば
Dialogue: 1,0:07:23.04,0:07:23.81,jp,Suguri,0,0,0,,はい
Dialogue: 1,0:07:23.81,0:07:26.67,jp,Sayuri,0,0,0,,この前傑里さん　言ってましたよね
Dialogue: 1,0:07:26.67,0:07:28.37,jp,Sayuri,0,0,0,,姉妹5人って
Dialogue: 1,0:07:29.58,0:07:32.15,jp,Sayuri,0,0,0,,いるんですか　もう1人
Dialogue: 1,0:07:32.70,0:07:37.02,jp,Suguri,0,0,0,,いえ　すみません　言い間違えました
Dialogue: 1,0:07:46.38,0:07:48.42,jp,Sayuri,0,0,0,,あ ありがとう
Dialogue: 1,0:07:48.42,0:07:49.61,jp,Sayuri,0,0,0,,みんなは
Dialogue: 1,0:07:49.61,0:07:52.03,jp,Rina,0,0,0,,部長は寿桃さんのとこ
Dialogue: 1,0:07:52.03,0:07:54.17,jp,Rina,0,0,0,,希は庵珠ちゃんのとこ
Dialogue: 1,0:07:54.17,0:07:56.20,jp,Rina,0,0,0,,七瀬は夏夢さんのとこ
Dialogue: 1,0:07:56.20,0:07:58.69,jp,Sayuri,0,0,0,,うん　みんな仲よしだね
Dialogue: 1,0:07:58.69,0:08:01.21,jp,Rina,0,0,0,,仲よくしないほうがいいのに
Dialogue: 1,0:08:01.21,0:08:05.14,jp,Sayuri,0,0,0,,そ　そうだよね　歴史変えちゃうかもだもんね
Dialogue: 1,0:08:05.14,0:08:06.82,jp,Rina,0,0,0,,そうじゃなくて
Dialogue: 1,0:08:08.25,0:08:08.96,jp,Rina,0,0,0,,麻衣
Dialogue: 1,0:08:11.75,0:08:12.90,jp,Sayuri,0,0,0,,こっちも
Dialogue: 1,0:08:13.56,0:08:16.66,jp,Sayuri,0,0,0,,麻衣ちゃん　プールとかですぐなくしちゃうから
Dialogue: 1,0:08:16.66,0:08:17.97,jp,Rina,0,0,0,,子どもか
Dialogue: 1,0:08:18.23,0:08:22.15,jp,Sayuri,0,0,0,,ね　春ちゃんもそう言いながら縫ってたな
Dialogue: 1,0:08:22.15,0:08:23.48,jp,Rina,0,0,0,,春ちゃん
Dialogue: 1,0:08:23.48,0:08:25.84,jp,Mai,0,0,0,,はい　これで出来上がり
Dialogue: 1,0:08:25.84,0:08:27.23,jp,Sumomo,0,0,0,,わぁ　きれい
Dialogue: 1,0:08:27.23,0:08:29.50,jp,Mai,0,0,0,,これね　こうやって
Dialogue: 1,0:08:31.42,0:08:34.57,jp,Sumomo,0,0,0,,すごい　これ麻衣が考えたの
Dialogue: 1,0:08:34.57,0:08:37.84,jp,Mai,0,0,0,,ううん　春ちゃんに教えてもらったんだ
Dialogue: 1,0:08:37.84,0:08:38.95,jp,Sumomo,0,0,0,,春ちゃん
Dialogue: 1,0:08:38.95,0:08:43.25,jp,Mai,0,0,0,,うん　10歳の時からね　私を育ててくれた人
Dialogue: 1,0:08:44.49,0:08:48.09,jp,Rina,0,0,0,,亡くなっているんですよね　部長のご両親
Dialogue: 1,0:08:48.55,0:08:51.86,jp,Sayuri,0,0,0,,うん　麻衣ちゃんが10歳の時
Dialogue: 1,0:08:53.33,0:08:56.64,jp,Mai,0,0,0,,お父さんとお母さんボウリングが大好きでね
Dialogue: 1,0:08:56.64,0:08:59.26,jp,Mai,0,0,0,,私もちっちゃい頃から教えてもらって
Dialogue: 1,0:08:59.26,0:09:01.18,jp,Mai,0,0,0,,クラブにも入れてもらってね
Dialogue: 1,0:09:02.15,0:09:03.98,jp,Mai,0,0,0,,私が試合で勝つと
Dialogue: 1,0:09:03.98,0:09:07.39,jp,Mai,0,0,0,,お父さんとお母さんめっちゃ喜んでくれてね
Dialogue: 1,0:09:07.39,0:09:10.38,jp,Mai,0,0,0,,私　それがめっちゃ嬉しくてさ
Dialogue: 1,0:09:11.21,0:09:13.71,jp,Mai,0,0,0,,その日もね　試合だったんだ
Dialogue: 1,0:09:14.41,0:09:17.49,jp,Mai,0,0,0,,私はクラブのみんなとバスで行ってね
Dialogue: 1,0:09:17.49,0:09:21.45,jp,Mai,0,0,0,,お父さんとお母さんは車で来てくれることになってたの
Dialogue: 1,0:09:21.91,0:09:22.87,jp,Mai,0,0,0,,でも
Dialogue: 1,0:09:27.37,0:09:30.82,jp,Sayuri,0,0,0,,会場に向かう途中の事故だったんだって
Dialogue: 1,0:09:30.82,0:09:33.38,jp,Sayuri,0,0,0,,居眠り運転のトラックに
Dialogue: 1,0:09:33.61,0:09:37.98,jp,Sayuri,0,0,0,,麻衣ちゃん　最初は親戚のお家に引き取られたんだけど
Dialogue: 1,0:09:37.98,0:09:40.57,jp,Sayuri,0,0,0,,あんまり　うまくいかなかったみたいで
Dialogue: 1,0:09:41.14,0:09:45.71,jp,Mai,0,0,0,,わかるよ　自分のこと嫌がってる人がいるとこにいたくないの
Dialogue: 1,0:09:46.47,0:09:49.31,jp,Sayuri,0,0,0,,簡単になんか言ってないよ　麻衣ちゃんは
Dialogue: 1,0:09:53.63,0:09:55.81,jp,Mai,0,0,0,,それで　施設に移ってね
Dialogue: 1,0:09:58.17,0:10:02.11,jp,Mai,0,0,0,,そこにボランティアで来てた春ちゃんが里親になってくれたの
Dialogue: 1,0:10:03.62,0:10:06.53,jp,Mai,0,0,0,,あっ　えと　施設っていうのはね
Dialogue: 1,0:10:06.53,0:10:07.75,jp,Sumomo,0,0,0,,どうやったの
Dialogue: 1,0:10:08.10,0:10:08.62,jp,Mai,0,0,0,,え
Dialogue: 1,0:10:08.62,0:10:12.90,jp,Sumomo,0,0,0,,そんなに悲しいことがあったのに　一人ぼっちになったのに
Dialogue: 1,0:10:13.25,0:10:15.45,jp,Sumomo,0,0,0,,どうやって今の麻衣になったの
Dialogue: 1,0:10:16.26,0:10:17.35,jp,Mai,0,0,0,,今の
Dialogue: 1,0:10:17.97,0:10:20.39,jp,Sumomo,0,0,0,,今のお日様みたいな麻衣に
Dialogue: 1,0:10:20.39,0:10:24.71,jp,Mai,0,0,0,,お　お日様　えへへ　照れるな　そんな
Dialogue: 1,0:10:25.14,0:10:26.64,jp,Sumomo,0,0,0,,教えて
Dialogue: 1,0:10:31.09,0:10:34.06,jp,Mai,0,0,0,,春ちゃんと会えたから　かな
Dialogue: 1,0:10:34.52,0:10:36.53,jp,Sumomo,0,0,0,,そっか
Dialogue: 1,0:10:36.78,0:10:41.03,jp,Mai,0,0,0,,ごめん　暗い話しちゃって　ボウリングしよう
Dialogue: 1,0:10:41.47,0:10:43.53,jp,Sumomo,0,0,0,,麻衣　私
Dialogue: 1,0:10:43.53,0:10:46.41,jp,Mai,0,0,0,,わかってる　外出たくないんだよね
Dialogue: 1,0:10:46.41,0:10:49.54,jp,Mai,0,0,0,,ほら　あれあれ　前に寿桃ちゃんがやってた
Dialogue: 1,0:10:50.47,0:10:54.17,jp,Sumomo,0,0,0,,ごめんなさい　捨てちゃったの　全部
Dialogue: 1,0:10:54.90,0:10:55.71,jp,Mai,0,0,0,,えっ
Dialogue: 1,0:10:55.71,0:10:57.93,jp,Sumomo,0,0,0,,飽きちゃった　ボウリング
Dialogue: 1,0:11:00.19,0:11:01.30,jp,Mai,0,0,0,,そっか
Dialogue: 1,0:11:01.30,0:11:04.66,jp,Sumomo,0,0,0,,ねっ　麻衣　折り紙もっと教えて
Dialogue: 1,0:11:05.35,0:11:07.93,jp,Mai,0,0,0,,いいよ　はまったね
Dialogue: 1,0:11:09.81,0:11:12.66,jp,Sumomo,0,0,0,,これ　1人でも楽しいもんね
Dialogue: 1,0:11:14.55,0:11:17.74,jp,Sumomo,0,0,0,,考えたの　1人でも楽しい遊び
Dialogue: 1,0:11:19.38,0:11:23.14,jp,Mai,0,0,0,,寿桃ちゃん　七瀬と夏夢さんが言ってたよ
Dialogue: 1,0:11:23.14,0:11:26.33,jp,Mai,0,0,0,,温泉ってね　人を呼べるだけじゃなくて
Dialogue: 1,0:11:26.33,0:11:31.16,jp,Mai,0,0,0,,お湯の熱で作物育てたりとか　いろんなことに使えるって
Dialogue: 1,0:11:31.16,0:11:32.42,jp,Mai,0,0,0,,そしたら　ここ
Dialogue: 1,0:11:32.42,0:11:35.34,jp,Mai,0,0,0,,よその国に守ってもらわなくてもよくなるって
Dialogue: 1,0:11:38.27,0:11:39.85,jp,Mai,0,0,0,,だから大丈夫だよ
Dialogue: 1,0:11:40.42,0:11:44.05,jp,Mai,0,0,0,,もし　もしね　お馬がなかなか来なくて
Dialogue: 1,0:11:44.05,0:11:45.76,jp,Mai,0,0,0,,寿桃ちゃんがお嫁に行けなくても
Dialogue: 1,0:11:45.76,0:11:46.61,jp,Sumomo,0,0,0,,だめなの
Dialogue: 1,0:11:47.35,0:11:52.35,jp,Sumomo,0,0,0,,だめなの　行かなければならないの　絶対に
Dialogue: 1,0:11:52.35,0:11:53.35,jp,Mai,0,0,0,,どうして
Dialogue: 1,0:11:54.22,0:11:58.51,jp,Sayuri,0,0,0,,でもね　踏み込んじゃいけないとこなんだって思ったの
Dialogue: 1,0:11:58.51,0:12:01.53,jp,Nanase,0,0,0,,価値観の違いを安易に否定することは
Dialogue: 1,0:12:01.53,0:12:05.50,jp,Nanase,0,0,0,,それまでの人生を否定することにもなりかねませんからね
Dialogue: 1,0:12:06.37,0:12:07.49,jp,Sumomo,0,0,0,,麻衣
Dialogue: 1,0:12:08.94,0:12:11.62,jp,Sumomo,0,0,0,,なれるかな　私も　お日様に
Dialogue: 1,0:12:13.05,0:12:15.63,jp,Sumomo,0,0,0,,会えるかな　私も
Dialogue: 1,0:12:15.63,0:12:19.01,jp,Sumomo,0,0,0,,一人ぼっちになった後　私の春ちゃんに
Dialogue: 1,0:12:24.61,0:12:26.05,jp,Anzu,0,0,0,,雷
Dialogue: 1,0:12:26.30,0:12:28.02,jp,Nozomi,0,0,0,,うん　あったじゃん
Dialogue: 1,0:12:28.02,0:12:32.25,jp,Nozomi,0,0,0,,こないだピカピカって光ってドカーンって落ちるやつ
Dialogue: 1,0:12:32.25,0:12:35.98,jp,Anzu,0,0,0,,知ってる　子どもだと思ってばかにするな
Dialogue: 1,0:12:36.62,0:12:38.32,jp,Nozomi,0,0,0,,ごめん　ごめん
Dialogue: 1,0:12:41.05,0:12:44.73,jp,Natsume,0,0,0,,そうか　やっぱり雷なんだね
Dialogue: 1,0:12:44.73,0:12:48.46,jp,Nanase,0,0,0,,はい　私たちがここに来たときもそうでした
Dialogue: 1,0:12:48.46,0:12:52.11,jp,Natsume,0,0,0,,雷の何が時間移動に関係してるのかわかれば
Dialogue: 1,0:12:52.11,0:12:56.35,jp,Natsume,0,0,0,,雷を待たずとも　帰れる方法が見つかるかもしれないね
Dialogue: 1,0:13:00.10,0:13:02.09,jp,Anzu,0,0,0,,帰ってしまうのか
Dialogue: 1,0:13:02.94,0:13:08.70,jp,Anzu,0,0,0,,今度　雷が来たら　希たちは　ミライへ
Dialogue: 1,0:13:11.75,0:13:17.11,jp,Nanase,0,0,0,,帰らなくてもいいかな　なんて思っちゃったりしてます実は
Dialogue: 1,0:13:17.11,0:13:18.02,jp,Natsume,0,0,0,,え
Dialogue: 1,0:13:18.02,0:13:20.32,jp,Nanase,0,0,0,,私　高校入って
Dialogue: 1,0:13:20.32,0:13:23.72,jp,Nanase,0,0,0,,あの人たちに会うまで　本当に空気で
Dialogue: 1,0:13:23.72,0:13:26.57,jp,Nanase,0,0,0,,休み時間　図書室に入り浸って
Dialogue: 1,0:13:26.57,0:13:29.53,jp,Nanase,0,0,0,,手あたりしだい　本読みまくってたんです
Dialogue: 1,0:13:29.98,0:13:34.25,jp,Nanase,0,0,0,,その時　目的もなく詰め込んだ知識が
Dialogue: 1,0:13:34.25,0:13:36.15,jp,Nanase,0,0,0,,初めてこんなに役立って
Dialogue: 1,0:13:36.75,0:13:37.93,jp,Natsume,0,0,0,,初めて
Dialogue: 1,0:13:39.17,0:13:41.95,jp,Nanase,0,0,0,,知識なんかなくても生きられる世界なんです
Dialogue: 1,0:13:41.95,0:13:43.92,jp,Nanase,0,0,0,,PCとかスマホとか
Dialogue: 1,0:13:43.92,0:13:46.85,jp,Nanase,0,0,0,,なんでも一瞬で調べられる機械もあるし
Dialogue: 1,0:13:47.98,0:13:50.38,jp,Natsume,0,0,0,,一瞬で調べられる機械
Dialogue: 1,0:13:51.10,0:13:55.06,jp,Nanase,0,0,0,,初めてなんですよ　こんなになんていうか
Dialogue: 1,0:13:55.06,0:13:57.87,jp,Nanase,0,0,0,,活躍してるぞ私　みたいなの
Dialogue: 1,0:14:00.82,0:14:04.57,jp,Nanase,0,0,0,,心配しないでください　わかってます　帰ります
Dialogue: 1,0:14:04.57,0:14:07.62,jp,Nanase,0,0,0,,ちゃんと連れて帰らなきゃ　あの人たち
Dialogue: 1,0:14:09.75,0:14:14.83,jp,Natsume,0,0,0,,心配なんかしてないよ　引き止めたくなっちゃっただけ
Dialogue: 1,0:14:17.67,0:14:21.42,jp,Nanase,0,0,0,,あっそういえば　空から光の塊が下りてきたとき
Dialogue: 1,0:14:21.42,0:14:23.49,jp,Nanase,0,0,0,,あなたたちは何をしてたんですか
Dialogue: 1,0:14:24.02,0:14:24.81,jp,Natsume,0,0,0,,え
Dialogue: 1,0:14:24.81,0:14:29.09,jp,Nanase,0,0,0,,そこに何か手がかりがあるかもしれないと思いまして
Dialogue: 1,0:14:29.09,0:14:30.64,jp,Natsume,0,0,0,,ボウリングだよ
Dialogue: 1,0:14:30.64,0:14:31.34,jp,Nanase,0,0,0,,えっ
Dialogue: 1,0:14:31.61,0:14:34.19,jp,Natsume,0,0,0,,知ってる　愉快だよ
Dialogue: 1,0:14:34.19,0:14:37.35,jp,Natsume,0,0,0,,枝を並べて　毬を転がして倒すんだよ
Dialogue: 1,0:14:37.64,0:14:39.69,jp,Natsume,0,0,0,,あの人が教えてくれたんだ
Dialogue: 1,0:14:39.69,0:14:42.54,jp,Natsume,0,0,0,,昔よく子どもと一緒にやったって
Dialogue: 1,0:14:47.07,0:14:48.18,jp,Mai,0,0,0,,利奈
Dialogue: 1,0:14:52.97,0:14:55.53,jp,Mai,0,0,0,,わっ　ご　ごめんね　勝手に
Dialogue: 1,0:14:55.53,0:14:59.09,jp,Mai,0,0,0,,神社のボウリング場　村のみんなが使ってて
Dialogue: 1,0:14:59.62,0:15:02.66,jp,Rina,0,0,0,,別に　私だけの場所じゃない
Dialogue: 1,0:15:03.37,0:15:07.63,jp,Mai,0,0,0,,そっか　利奈　みんなのために作ってくれたんだもんね
Dialogue: 1,0:15:09.67,0:15:10.70,jp,Rina,0,0,0,,別に
Dialogue: 1,0:15:21.69,0:15:24.40,jp,Nanase,0,0,0,,なわけないか　都合よすぎ
Dialogue: 1,0:15:24.40,0:15:25.65,jp,Nozomi,0,0,0,,何が
Dialogue: 1,0:15:25.65,0:15:27.38,jp,Nanase,0,0,0,,ひ　独り言です
Dialogue: 1,0:15:28.22,0:15:30.77,jp,Nanase,0,0,0,,にしても来ませんね　雷
Dialogue: 1,0:15:30.77,0:15:32.84,jp,Nozomi,0,0,0,,ねぇ　七瀬
Dialogue: 1,0:15:32.84,0:15:33.87,jp,Nanase,0,0,0,,はい
Dialogue: 1,0:15:34.21,0:15:36.66,jp,Nozomi,0,0,0,,なんで帰んなきゃいけないんだっけ
Dialogue: 1,0:15:38.30,0:15:40.41,jp,Nanase,0,0,0,,それ　言いますか
Dialogue: 1,0:15:44.43,0:15:47.67,jp,Mai,0,0,0,,あ　楽しかった　ありがとね　利奈
Dialogue: 1,0:15:48.91,0:15:50.49,jp,Rina,0,0,0,,関係あるの
Dialogue: 1,0:15:50.49,0:15:51.42,jp,Mai,0,0,0,,え
Dialogue: 1,0:15:51.42,0:15:55.01,jp,Rina,0,0,0,,部長が試合で勝てないの　ご両親のことと
Dialogue: 1,0:15:56.43,0:15:58.39,jp,Rina,0,0,0,,さゆりに聞いた
Dialogue: 1,0:15:58.39,0:16:01.94,jp,Rina,0,0,0,,私に知られたくなかったことだったら　ごめんなさい
Dialogue: 1,0:16:02.44,0:16:05.44,jp,Mai,0,0,0,,ううん　全然そんなことないよ
Dialogue: 1,0:16:05.44,0:16:08.96,jp,Mai,0,0,0,,利奈に隠してたとか　そんなんじゃ全然なくてね
Dialogue: 1,0:16:08.96,0:16:11.34,jp,Mai,0,0,0,,ほら　暗いじゃん　あんな話
Dialogue: 1,0:16:11.34,0:16:12.56,jp,Rina,0,0,0,,暗くない
Dialogue: 1,0:16:12.56,0:16:13.46,jp,Mai,0,0,0,,え
Dialogue: 1,0:16:13.46,0:16:15.34,jp,Rina,0,0,0,,暗い話なんかじゃない
Dialogue: 1,0:16:15.75,0:16:18.45,jp,Rina,0,0,0,,部長が頑張った　強い話
Dialogue: 1,0:16:21.21,0:16:22.46,jp,Mai,0,0,0,,ありがと
Dialogue: 1,0:16:31.87,0:16:34.72,jp,Mai,0,0,0,,わかんないんだ　ホントに
Dialogue: 1,0:16:34.72,0:16:39.21,jp,Mai,0,0,0,,勝てなくなったのそれからだから　なんか関係あるんだとは思う
Dialogue: 1,0:16:39.62,0:16:44.19,jp,Mai,0,0,0,,けどわかんないんだよね　自分でも　どうしてなのか
Dialogue: 1,0:16:44.62,0:16:45.72,jp,Rina,0,0,0,,ターキー
Dialogue: 1,0:16:45.72,0:16:46.34,jp,Mai,0,0,0,,えっ
Dialogue: 1,0:16:46.34,0:16:48.39,jp,Rina,0,0,0,,ターキー取ると変になる
Dialogue: 1,0:16:49.19,0:16:51.09,jp,Mai,0,0,0,,うん　何が
Dialogue: 1,0:16:51.09,0:16:52.21,jp,Rina,0,0,0,,部長が
Dialogue: 1,0:16:52.21,0:16:53.24,jp,Mai,0,0,0,,私
Dialogue: 1,0:16:53.24,0:16:55.28,jp,Rina,0,0,0,,いつもそこまでは絶好調で
Dialogue: 1,0:16:56.25,0:16:59.24,jp,Rina,0,0,0,,第4フレームからガタガタになる
Dialogue: 1,0:16:59.24,0:17:00.62,jp,Mai,0,0,0,,確かに
Dialogue: 1,0:17:01.77,0:17:05.37,jp,Rina,0,0,0,,ごめんなさい　わざと負けてるとか言って
Dialogue: 1,0:17:06.21,0:17:08.71,jp,Mai,0,0,0,,ううん　私もごめん
Dialogue: 1,0:17:09.70,0:17:12.37,jp,Mai,0,0,0,,利奈の気持ち　ずっとわかってなかった
Dialogue: 1,0:17:13.65,0:17:15.71,jp,Mai,0,0,0,,考えるからね　私
Dialogue: 1,0:17:16.61,0:17:18.70,jp,Mai,0,0,0,,利奈を1人にしない方法
Dialogue: 1,0:17:19.10,0:17:20.66,jp,Rina,0,0,0,,私も考える
Dialogue: 1,0:17:22.18,0:17:23.26,jp,Rina,0,0,0,,部長が
Dialogue: 1,0:17:25.15,0:17:27.52,jp,Rina,0,0,0,,部長と勝てる方法
Dialogue: 1,0:17:29.13,0:17:30.27,jp,Mai,0,0,0,,ありがとう
Dialogue: 1,0:17:31.07,0:17:33.25,jp,Rina,0,0,0,,その前に帰らなきゃだけどね
Dialogue: 1,0:17:38.78,0:17:39.70,jp,Mai,0,0,0,,だね
Dialogue: 1,0:17:58.31,0:17:59.30,jp,Mai,0,0,0,,ボウリング
Dialogue: 1,0:17:59.67,0:18:01.41,jp,Nozomi,0,0,0,,なに
Dialogue: 1,0:18:01.41,0:18:03.82,jp,Mai,0,0,0,,ねっ　今ボウリングの音しなかった
Dialogue: 1,0:18:03.82,0:18:05.53,jp,Sayuri,0,0,0,,ボウリングの音
Dialogue: 1,0:18:05.53,0:18:08.77,jp,Nanase,0,0,0,,ボウリングの音だったら何なんですか
Dialogue: 1,0:18:09.31,0:18:11.45,jp,Mai,0,0,0,,ね ねっ　聞こえたでしょ
Dialogue: 1,0:18:11.45,0:18:12.88,jp,Sayuri,0,0,0,,聞こえた
Dialogue: 1,0:18:12.88,0:18:14.46,jp,Mai,0,0,0,,誰がやってるんだろ
Dialogue: 1,0:18:14.46,0:18:16.07,jp,Nanase,0,0,0,,いやいやいやいや
Dialogue: 1,0:18:16.07,0:18:17.12,jp,Nozomi,0,0,0,,ないから
Dialogue: 1,0:18:17.12,0:18:20.41,jp,Nanase,0,0,0,,誰がやるんですか　こんな深夜にボウリング
Dialogue: 1,0:18:20.82,0:18:23.67,jp,Sayuri,0,0,0,,えぇ　じゃあ　この音
Dialogue: 1,0:18:24.08,0:18:24.97,jp,Rina,0,0,0,,泥棒
Dialogue: 1,0:18:27.75,0:18:30.83,jp,Sayuri,0,0,0,,やっぱり　傑里さん呼んだほうが
Dialogue: 1,0:18:31.10,0:18:34.06,jp,Nanase,0,0,0,,っていうか　なんで私が先頭なんですか
Dialogue: 1,0:18:34.06,0:18:36.58,jp,Nozomi,0,0,0,,あんたがいちばんちっちゃいからでしょ
Dialogue: 1,0:18:36.58,0:18:37.71,jp,Nanase,0,0,0,,背の順
Dialogue: 1,0:18:38.59,0:18:40.67,jp,Nozomi,0,0,0,,は　なんでボール持参
Dialogue: 1,0:18:40.67,0:18:43.22,jp,Mai,0,0,0,,えっ　ボウリングだったら参加でしょ
Dialogue: 1,0:18:43.22,0:18:46.96,jp,Nozomi,0,0,0,,あんたたちマジでボウリングのなんなの　下僕
Dialogue: 1,0:18:46.96,0:18:47.98,jp,Rina,0,0,0,,下僕
Dialogue: 1,0:18:49.23,0:18:52.77,jp,Nanase,0,0,0,,近くなってきましたね　音が
Dialogue: 1,0:18:55.29,0:18:56.85,jp,Nanase,0,0,0,,行き止まりです
Dialogue: 1,0:18:56.85,0:18:58.35,jp,Mai,0,0,0,,えっ　どゆこと
Dialogue: 1,0:18:59.47,0:19:02.22,jp,Sayuri,0,0,0,,かかか　壁の中から
Dialogue: 1,0:19:02.22,0:19:05.53,jp,Nozomi,0,0,0,,えっ　何これ　そっち系　怖い系
Dialogue: 1,0:19:05.53,0:19:07.27,jp,Mai,0,0,0,,そっち系って　どっち系
Dialogue: 1,0:19:07.27,0:19:09.30,jp,Mai,0,0,0,,ゾンビ系　グロイ系
Dialogue: 1,0:19:09.30,0:19:12.57,jp,Nozomi,0,0,0,,怖い系って言ったでしょ　ホラー系
Dialogue: 1,0:19:12.57,0:19:16.75,jp,Mai,0,0,0,,ホ　ホラー系　貞子　伽椰子　マイケル　どれ
Dialogue: 1,0:19:17.47,0:19:20.03,jp,Nozomi,0,0,0,,事故物件的なやつでしょ
Dialogue: 1,0:19:46.43,0:19:47.54,jp,Nozomi,0,0,0,,怖っ
Dialogue: 1,0:19:48.93,0:19:49.77,jp,Mai,0,0,0,,行こ
Dialogue: 1,0:19:49.77,0:19:50.79,jp,Sayuri,0,0,0,,えっ
Dialogue: 1,0:19:50.79,0:19:52.43,jp,Nozomi,0,0,0,,いやいやいやいや
Dialogue: 1,0:19:52.52,0:19:54.79,jp,Sayuri,0,0,0,,やめたほうが
Dialogue: 1,0:19:54.79,0:19:58.02,jp,Mai,0,0,0,,利奈のカバン　取りに行かなきゃ
Dialogue: 1,0:20:01.85,0:20:03.81,jp,Nozomi,0,0,0,,ちょっと押さないでよ
Dialogue: 1,0:20:03.81,0:20:07.21,jp,Rina,0,0,0,,押してない　そっちが遅いからつっかえてる
Dialogue: 1,0:20:11.75,0:20:12.75,jp,Nozomi,0,0,0,,こっわ
Dialogue: 1,0:20:12.75,0:20:14.06,jp,Sayuri,0,0,0,,地下室
Dialogue: 1,0:20:15.02,0:20:16.15,jp,Nanase,0,0,0,,戻りましょう
Dialogue: 1,0:20:16.15,0:20:16.85,jp,Mai,0,0,0,,えっ
Dialogue: 1,0:20:16.85,0:20:20.39,jp,Nanase,0,0,0,,それこそ　踏み込んじゃいけない場所です　きっと
Dialogue: 1,0:20:20.75,0:20:23.01,jp,Nanase,0,0,0,,麻衣さん　早くボールの回収を
Dialogue: 1,0:20:23.77,0:20:25.59,jp,Mai,0,0,0,,あっ　うん
Dialogue: 1,0:20:43.59,0:20:44.49,jp,Akebi,0,0,0,,誰だ
Dialogue: 1,0:20:51.06,0:20:52.85,jp,Mai,0,0,0,,寿桃ちゃん
Dialogue: 1,0:20:52.85,0:20:53.90,jp,Sumomo,0,0,0,,麻衣
Dialogue: 1,0:20:54.85,0:20:55.85,jp,Mai,0,0,0,,えっ
Dialogue: 1,0:20:56.85,0:20:57.83,jp,Nanase,0,0,0,,やっぱり
Dialogue: 1,0:20:57.83,0:20:58.46,jp,Nozomi,0,0,0,,えっ
Dialogue: 1,0:20:58.46,0:21:00.82,jp,Suguri,0,0,0,,見てしまわれたんですね
Dialogue: 1,0:21:12.25,0:21:13.42,jp,Suguri,0,0,0,,この家の
Dialogue: 1,0:21:15.31,0:21:16.67,jp,Suguri,0,0,0,,秘密を
Comment: 0,0:00:36.41,0:00:38.41,CN,,0,0,0,,OP前
Dialogue: 0,0:00:38.41,0:00:38.93,CN,Anzu,0,0,0,,來吧
Dialogue: 0,0:01:15.09,0:01:17.37,CN,Mai,0,0,0,,完成啦
Dialogue: 0,0:01:21.34,0:01:24.06,CN,Natsume,0,0,0,,今後 無論什麼都會改變呢
Dialogue: 0,0:01:25.14,0:01:27.85,CN,Natsume,0,0,0,,不用靠他人的庇護而自力更生
Dialogue: 0,0:01:27.85,0:01:29.78,CN,Natsume,0,0,0,,這個國家肯定能做到
Dialogue: 0,0:01:31.73,0:01:36.42,CN,Suguri,0,0,0,,她們幾位 難道是神明派遣而來的嗎
Dialogue: 0,0:01:37.66,0:01:39.84,CN,Natsume,0,0,0,,對不起 傑里
Dialogue: 0,0:01:41.47,0:01:43.83,CN,Natsume,0,0,0,,一個人挑擔過於沉重吧
Dialogue: 0,0:01:44.33,0:01:47.71,CN,Natsume,0,0,0,,既要出戰 又要護國
Dialogue: 0,0:01:47.71,0:01:50.38,CN,Natsume,0,0,0,,還有家庭 妹妹們
Dialogue: 0,0:01:51.27,0:01:53.38,CN,Natsume,0,0,0,,向坂城大人卑躬屈膝
Dialogue: 0,0:01:55.76,0:01:57.00,CN,Suguri,0,0,0,,真不甘心啊
Dialogue: 0,0:01:57.88,0:02:02.25,CN,Suguri,0,0,0,,我在別人面前 多少已經游刃有餘了
Dialogue: 0,0:02:03.05,0:02:05.29,CN,Suguri,0,0,0,,但 還是騙不了你
Dialogue: 0,0:02:06.07,0:02:10.48,CN,Suguri,0,0,0,,再見到你的瞬間 一時間忘乎所以了
Dialogue: 0,0:02:07.78,0:02:10.14,CN - up,Sumomo,0,0,0,,姐姐大人
Dialogue: 0,0:02:10.14,0:02:13.65,CN - up,Mai,0,0,0,,喂 溫泉湧出來啦
Dialogue: 0,0:02:10.49,0:02:12.99,CN,Suguri,0,0,0,,想著這一切都能解決了
Dialogue: 0,0:02:14.57,0:02:18.82,CN,Suguri,0,0,0,,只要你能嫁入坂城大人府上就好了
Dialogue: 0,0:02:20.31,0:02:23.11,CN,Natsume,0,0,0,,是啊 我很抱歉
Dialogue: 0,0:02:23.59,0:02:27.17,CN,Suguri,0,0,0,,沒什麼 我卻因此而感到羞愧
Dialogue: 0,0:02:28.85,0:02:29.67,CN,Natsume,0,0,0,,為何
Dialogue: 0,0:02:30.46,0:02:35.49,CN,Suguri,0,0,0,,明明夏夢你的內心嚮往著自由
Dialogue: 0,0:02:35.87,0:02:40.79,CN,Suguri,0,0,0,,我竟想自私地把你禁錮在我卑鄙的內心
Dialogue: 0,0:02:42.73,0:02:45.07,CN,Suguri,0,0,0,,請原諒我 姐姐
Dialogue: 0,0:02:46.10,0:02:48.25,CN,Natsume,0,0,0,,不愧是我們的父親
Dialogue: 0,0:02:48.59,0:02:49.19,CN,Suguri,0,0,0,,欸
Dialogue: 0,0:02:49.19,0:02:52.77,CN,Natsume,0,0,0,,他早就看出來了 在你小的時候
Dialogue: 0,0:02:52.77,0:02:54.87,CN,Natsume,0,0,0,,有成為一國之主的氣度
Dialogue: 0,0:02:55.70,0:02:58.66,CN,Suguri,0,0,0,,欸欸 怎 怎麼會 不可能的
Dialogue: 0,0:02:58.66,0:03:01.45,CN,Natsume,0,0,0,,但是傑里 請你不要忘記
Dialogue: 0,0:03:01.45,0:03:03.70,CN,Natsume,0,0,0,,你也是自由的
Dialogue: 0,0:03:04.22,0:03:09.35,CN,Natsume,0,0,0,,我雖然嚮往自由 但絕不是讓你一人承擔所有
Dialogue: 0,0:03:09.35,0:03:10.71,CN,Suguri,0,0,0,,姐姐
Dialogue: 0,0:03:11.67,0:03:14.29,CN,Natsume,0,0,0,,不會讓你一人背負全部的
Dialogue: 0,0:03:14.29,0:03:17.75,CN,Natsume,0,0,0,,國 家 妹妹們
Dialogue: 0,0:03:19.11,0:03:20.47,CN,Natsume,0,0,0,,還有
Dialogue: 0,0:03:22.50,0:03:26.72,CN,Natsume,0,0,0,,這家裡的 悲愛的秘密
Comment: 0,0:05:00.78,0:05:02.78,CN,,0,0,0,,
Dialogue: 0,0:05:02.78,0:05:04.75,CN,Mai,0,0,0,,融化了
Dialogue: 0,0:05:04.75,0:05:06.70,CN,Sayuri,0,0,0,,融化了啊
Dialogue: 0,0:05:06.70,0:05:08.45,CN,Nozomi,0,0,0,,融了呢
Dialogue: 0,0:05:08.45,0:05:10.45,CN,Nanase,0,0,0,,好耶夫人
Dialogue: 0,0:05:10.45,0:05:12.35,CN,Rina,0,0,0,,融化並消失
Dialogue: 0,0:05:13.85,0:05:17.14,CN,Rina,0,0,0,,但願不會發生吧 歷史已經被改變了
Dialogue: 0,0:05:18.21,0:05:21.09,CN,Nozomi,0,0,0,,你絕對是那種在暑假的時候
Dialogue: 0,0:05:21.09,0:05:24.43,CN,Nozomi,0,0,0,,追著別人問「暑假作業寫完了嗎」的類型
Dialogue: 0,0:05:24.43,0:05:25.97,CN,Rina,0,0,0,,意義不明
Dialogue: 0,0:05:25.97,0:05:30.41,CN,Mai,0,0,0,,算啦 消失什麼的 等真的發生了再說吧
Dialogue: 0,0:05:30.41,0:05:32.07,CN,Sayuri,0,0,0,,是啊
Dialogue: 0,0:05:32.07,0:05:34.11,CN,Rina,0,0,0,,消失的話根本來不及想
Dialogue: 0,0:05:34.95,0:05:37.65,CN,Nozomi,0,0,0,,說起來 我還挺意外的呢
Dialogue: 0,0:05:37.65,0:05:41.95,CN,Nozomi,0,0,0,,我以為你絕對會反對挖溫泉呢
Dialogue: 0,0:05:41.95,0:05:43.49,CN,Nanase,0,0,0,,這是因為
Dialogue: 0,0:05:43.49,0:05:46.89,CN,Nanase,0,0,0,,情非得已 欲罷不能吧
Dialogue: 0,0:05:47.24,0:05:50.45,CN,Mai,0,0,0,,突然就想投了吧 從掉溝到補中
Dialogue: 0,0:05:50.45,0:05:51.66,CN,Rina,0,0,0,,意義不明
Dialogue: 0,0:05:51.66,0:05:52.99,CN,Mai,0,0,0,,欸 為什麼
Dialogue: 0,0:05:53.22,0:05:56.15,CN,Nanase,0,0,0,,說起來 那句話是什麼意思來著
Dialogue: 0,0:05:56.15,0:05:56.75,CN,Mai,0,0,0,,嗯
Dialogue: 0,0:05:56.75,0:05:59.65,CN,Nanase,0,0,0,,壽桃她「掉溝」什麼的
Dialogue: 0,0:05:59.65,0:06:02.13,CN,Mai,0,0,0,,這個啊
Dialogue: 0,0:06:02.13,0:06:04.55,CN,Mai,0,0,0,,壽桃她說過
Dialogue: 0,0:06:04.55,0:06:07.26,CN,Mai,0,0,0,,沒有來生理期是自己的過錯
Dialogue: 0,0:06:07.77,0:06:10.63,CN,Mai,0,0,0,,就像是 糟了報應一樣
Dialogue: 0,0:06:10.63,0:06:11.66,CN,Nanase,0,0,0,,報應
Dialogue: 0,0:06:11.66,0:06:13.76,CN,Mai,0,0,0,,說是因為自己走出了家門
Dialogue: 0,0:06:14.46,0:06:16.11,CN,Mai,0,0,0,,欸 什麼意思
Dialogue: 0,0:06:16.77,0:06:23.02,CN,Sumomo,0,0,0,,走出家門 遇到她人 感到快樂的 只有我一人
Dialogue: 0,0:06:23.02,0:06:24.46,CN,Mai,0,0,0,,只有我
Dialogue: 0,0:06:24.46,0:06:26.03,CN,Sumomo,0,0,0,,沒什麼
Dialogue: 0,0:06:26.03,0:06:27.81,CN,Sumomo,0,0,0,,這個話題先結束啦
Dialogue: 0,0:06:28.19,0:06:29.03,CN,Mai,0,0,0,,這樣
Dialogue: 0,0:06:29.25,0:06:32.82,CN,Nozomi,0,0,0,,什麼鬼 這一點關係都沒有的吧
Dialogue: 0,0:06:32.82,0:06:35.42,CN,Mai,0,0,0,,是啊 完全就是「掉溝」了
Dialogue: 0,0:06:35.42,0:06:36.79,CN,Nozomi,0,0,0,,不是 你這也太
Dialogue: 0,0:06:36.79,0:06:38.28,CN,Rina,0,0,0,,意義不明
Dialogue: 0,0:06:38.28,0:06:39.94,CN,Sayuri,0,0,0,,嗯 就是掉溝了
Dialogue: 0,0:06:39.94,0:06:40.90,CN,Rina,0,0,0,,又通了
Dialogue: 0,0:06:40.90,0:06:42.79,CN,Nozomi,0,0,0,,不是 又這麼感動嗎
Dialogue: 0,0:06:43.77,0:06:45.49,CN,Mai,0,0,0,,七瀨你怎麼了
Dialogue: 0,0:06:45.49,0:06:47.42,CN,Nanase,0,0,0,,啊 沒什麼
Dialogue: 0,0:06:49.05,0:06:50.80,CN,Nanase,0,0,0,,我有點頭暈先出去了
Dialogue: 0,0:07:01.54,0:07:02.93,CN,Suguri,0,0,0,,歡迎回來
Dialogue: 0,0:07:03.27,0:07:05.53,CN,Sayuri,0,0,0,,對不起 打擾你了
Dialogue: 0,0:07:05.53,0:07:08.40,CN,Suguri,0,0,0,,沒什麼 泡澡還舒服嗎
Dialogue: 0,0:07:08.40,0:07:10.32,CN,Sayuri,0,0,0,,是的 那個
Dialogue: 0,0:07:10.32,0:07:13.60,CN,Sayuri,0,0,0,,我們還建造了單人專用的浴室
Dialogue: 0,0:07:13.60,0:07:14.08,CN,Suguri,0,0,0,,欸
Dialogue: 0,0:07:14.08,0:07:17.14,CN,Sayuri,0,0,0,,所以傑里大人你也可以去哦
Dialogue: 0,0:07:18.61,0:07:20.04,CN,Suguri,0,0,0,,非常感謝
Dialogue: 0,0:07:20.97,0:07:23.04,CN,Sayuri,0,0,0,,啊 說起來
Dialogue: 0,0:07:23.04,0:07:23.81,CN,Suguri,0,0,0,,嗯
Dialogue: 0,0:07:23.81,0:07:26.67,CN,Sayuri,0,0,0,,之前傑里大人曾說到過
Dialogue: 0,0:07:26.67,0:07:28.37,CN,Sayuri,0,0,0,,你們是姐妹五人
Dialogue: 0,0:07:29.58,0:07:32.15,CN,Sayuri,0,0,0,,還有一個人也存在嗎
Dialogue: 0,0:07:32.70,0:07:37.02,CN,Suguri,0,0,0,,沒有 對不起 是我說錯了
Dialogue: 0,0:07:46.38,0:07:48.42,CN,Sayuri,0,0,0,,啊 謝謝
Dialogue: 0,0:07:48.42,0:07:49.61,CN,Sayuri,0,0,0,,大家呢
Dialogue: 0,0:07:49.61,0:07:52.03,CN,Rina,0,0,0,,部長她在壽桃那裡
Dialogue: 0,0:07:52.03,0:07:54.17,CN,Rina,0,0,0,,希在庵珠那裡
Dialogue: 0,0:07:54.17,0:07:56.20,CN,Rina,0,0,0,,七瀨在夏夢那裡
Dialogue: 0,0:07:56.20,0:07:58.69,CN,Sayuri,0,0,0,,嗯 大家關係真好呢
Dialogue: 0,0:07:58.69,0:08:01.21,CN,Rina,0,0,0,,不應該關係這麼好的才對
Dialogue: 0,0:08:01.21,0:08:05.14,CN,Sayuri,0,0,0,,對 對啊 不然歷史可能會被改變呢
Dialogue: 0,0:08:05.14,0:08:06.82,CN,Rina,0,0,0,,不是這個意思
Dialogue: 0,0:08:08.25,0:08:08.96,CN,Rina,0,0,0,,麻衣
Dialogue: 0,0:08:11.75,0:08:12.90,CN,Sayuri,0,0,0,,這裡也有
Dialogue: 0,0:08:13.56,0:08:16.66,CN,Sayuri,0,0,0,,麻衣她 一去泳池之類的地方就總會弄丟的
Dialogue: 0,0:08:16.66,0:08:17.97,CN,Rina,0,0,0,,還是小孩嗎
Dialogue: 0,0:08:18.23,0:08:22.15,CN,Sayuri,0,0,0,,是吧 春醬刺繡的時候也這麼說呢
Dialogue: 0,0:08:22.15,0:08:23.48,CN,Rina,0,0,0,,春醬
Dialogue: 0,0:08:23.48,0:08:25.84,CN,Mai,0,0,0,,好啦 這就完成啦
Dialogue: 0,0:08:25.84,0:08:27.23,CN,Sumomo,0,0,0,,哇 好漂亮
Dialogue: 0,0:08:27.23,0:08:29.50,CN,Mai,0,0,0,,這個呢 這樣子
Dialogue: 0,0:08:31.42,0:08:34.57,CN,Sumomo,0,0,0,,好厲害 這也是麻衣想出來的嗎
Dialogue: 0,0:08:34.57,0:08:37.84,CN,Mai,0,0,0,,不是 是春醬教會我的
Dialogue: 0,0:08:37.84,0:08:38.95,CN,Sumomo,0,0,0,,春醬
Dialogue: 0,0:08:38.95,0:08:43.25,CN,Mai,0,0,0,,嗯 在我十歲的時候 撫養我的人
Dialogue: 0,0:08:44.49,0:08:48.09,CN,Rina,0,0,0,,部長的父母 都已經去世了吧
Dialogue: 0,0:08:48.55,0:08:51.86,CN,Sayuri,0,0,0,,嗯 在麻衣她十歲的時候
Dialogue: 0,0:08:53.33,0:08:56.64,CN,Mai,0,0,0,,我的爸爸和媽媽都最喜歡保齡球了
Dialogue: 0,0:08:56.64,0:08:59.26,CN,Mai,0,0,0,,所以從我小時候就開始教我
Dialogue: 0,0:08:59.26,0:09:01.18,CN,Mai,0,0,0,,還加入了俱樂部
Dialogue: 0,0:09:02.15,0:09:03.98,CN,Mai,0,0,0,,要是我比賽勝利的話
Dialogue: 0,0:09:03.98,0:09:07.39,CN,Mai,0,0,0,,他們倆會非常高興呢
Dialogue: 0,0:09:07.39,0:09:10.38,CN,Mai,0,0,0,,我也會超級快樂呢
Dialogue: 0,0:09:11.21,0:09:13.71,CN,Mai,0,0,0,,那天也是 我在一場比賽
Dialogue: 0,0:09:14.41,0:09:17.49,CN,Mai,0,0,0,,我和俱樂部的大家是坐大巴去的
Dialogue: 0,0:09:17.49,0:09:21.45,CN,Mai,0,0,0,,爸爸和媽媽是自己開車過來的
Dialogue: 0,0:09:21.91,0:09:22.87,CN,Mai,0,0,0,,但是
Dialogue: 0,0:09:27.37,0:09:30.82,CN,Sayuri,0,0,0,,他們在去往會場的途中出了車禍
Dialogue: 0,0:09:30.82,0:09:33.38,CN,Sayuri,0,0,0,,被疲勞駕駛的貨車撞了
Dialogue: 0,0:09:33.61,0:09:37.98,CN,Sayuri,0,0,0,,麻衣她 雖然最初是被親戚家收養了
Dialogue: 0,0:09:37.98,0:09:40.57,CN,Sayuri,0,0,0,,但是卻相處得並不好
Dialogue: 0,0:09:41.14,0:09:45.71,CN,Mai,0,0,0,,我明白的 誰都不想待在討厭自己的地方
Dialogue: 0,0:09:46.47,0:09:49.31,CN,Sayuri,0,0,0,,麻衣她才不是信口開河
Dialogue: 0,0:09:53.63,0:09:55.81,CN,Mai,0,0,0,,然後就轉去了福利院
Dialogue: 0,0:09:58.17,0:10:02.11,CN,Mai,0,0,0,,在那裡做義工的春醬 就成為了我的養母
Dialogue: 0,0:10:03.62,0:10:06.53,CN,Mai,0,0,0,,啊 那個 福利院的話就是
Dialogue: 0,0:10:06.53,0:10:07.75,CN,Sumomo,0,0,0,,你是如何做到的
Dialogue: 0,0:10:08.10,0:10:08.62,CN,Mai,0,0,0,,欸
Dialogue: 0,0:10:08.62,0:10:12.90,CN,Sumomo,0,0,0,,明明發生了這麼悲傷的事情 明明自己孤身一人
Dialogue: 0,0:10:13.25,0:10:15.45,CN,Sumomo,0,0,0,,你是如何成為現在的你呢
Dialogue: 0,0:10:16.26,0:10:17.35,CN,Mai,0,0,0,,現在的
Dialogue: 0,0:10:17.97,0:10:20.39,CN,Sumomo,0,0,0,,現在如同太陽般的麻衣
Dialogue: 0,0:10:20.39,0:10:24.71,CN,Mai,0,0,0,,太 太陽 欸嘿嘿  好害羞呀 沒那麼厲害啦
Dialogue: 0,0:10:25.14,0:10:26.64,CN,Sumomo,0,0,0,,教教我
Dialogue: 0,0:10:31.09,0:10:34.06,CN,Mai,0,0,0,,因為我遇見了春醬 吧
Dialogue: 0,0:10:34.52,0:10:36.53,CN,Sumomo,0,0,0,,這樣啊
Dialogue: 0,0:10:36.78,0:10:41.03,CN,Mai,0,0,0,,抱歉說了如此沉重的話題 來玩保齡球吧
Dialogue: 0,0:10:41.47,0:10:43.53,CN,Sumomo,0,0,0,,麻衣 我
Dialogue: 0,0:10:43.53,0:10:46.41,CN,Mai,0,0,0,,我明白的 你不想出門對吧
Dialogue: 0,0:10:46.41,0:10:49.54,CN,Mai,0,0,0,,那麼就玩那個吧 之前你做的那些
Dialogue: 0,0:10:50.47,0:10:54.17,CN,Sumomo,0,0,0,,對不起 我全部都 扔掉了
Dialogue: 0,0:10:54.90,0:10:55.71,CN,Mai,0,0,0,,欸
Dialogue: 0,0:10:55.71,0:10:57.93,CN,Sumomo,0,0,0,,我玩膩了 保齡球
Dialogue: 0,0:11:00.19,0:11:01.30,CN,Mai,0,0,0,,這樣啊
Dialogue: 0,0:11:01.30,0:11:04.66,CN,Sumomo,0,0,0,,吶 麻衣 教我更多的摺紙吧
Dialogue: 0,0:11:05.35,0:11:07.93,CN,Mai,0,0,0,,可以哦 你迷上了呢
Dialogue: 0,0:11:09.81,0:11:12.66,CN,Sumomo,0,0,0,,這個 一個人玩也挺開心的
Dialogue: 0,0:11:14.55,0:11:17.74,CN,Sumomo,0,0,0,,我在想 一個人也能快樂玩的遊戲
Dialogue: 0,0:11:19.38,0:11:23.14,CN,Mai,0,0,0,,壽桃 七瀨和夏夢曾經說過
Dialogue: 0,0:11:23.14,0:11:26.33,CN,Mai,0,0,0,,溫泉不僅僅能夠吸引人們
Dialogue: 0,0:11:26.33,0:11:31.16,CN,Mai,0,0,0,,還能用熱水培育作物 有各式各樣的用途
Dialogue: 0,0:11:31.16,0:11:32.42,CN,Mai,0,0,0,,這樣的話
Dialogue: 0,0:11:32.42,0:11:35.34,CN,Mai,0,0,0,,就算不依靠他國也能守護好這裡
Dialogue: 0,0:11:38.27,0:11:39.85,CN,Mai,0,0,0,,所以請放心吧
Dialogue: 0,0:11:40.42,0:11:44.05,CN,Mai,0,0,0,,假如 只是假如 你一直沒有入月
Dialogue: 0,0:11:44.05,0:11:45.76,CN,Mai,0,0,0,,就算壽桃你不出嫁也沒
Dialogue: 0,0:11:45.76,0:11:46.61,CN,Sumomo,0,0,0,,不行
Dialogue: 0,0:11:47.35,0:11:52.35,CN,Sumomo,0,0,0,,不行 無論如何我都必須要嫁過去
Dialogue: 0,0:11:52.35,0:11:53.35,CN,Mai,0,0,0,,為什麼
Dialogue: 0,0:11:54.22,0:11:58.51,CN,Sayuri,0,0,0,,但是 我覺得那是不能踏足的地方
Dialogue: 0,0:11:58.51,0:12:01.53,CN,Nanase,0,0,0,,價值觀的差異被輕易地否定
Dialogue: 0,0:12:01.53,0:12:05.50,CN,Nanase,0,0,0,,或許就是否定對方完整的人生吧
Dialogue: 0,0:12:06.37,0:12:07.49,CN,Sumomo,0,0,0,,麻衣
Dialogue: 0,0:12:08.94,0:12:11.62,CN,Sumomo,0,0,0,,我也能成為像你一樣的太陽嗎
Dialogue: 0,0:12:13.05,0:12:15.63,CN,Sumomo,0,0,0,,我也能遇得到嗎
Dialogue: 0,0:12:15.63,0:12:19.01,CN,Sumomo,0,0,0,,孤身一人之後 屬於我的春醬
Dialogue: 0,0:12:24.61,0:12:26.05,CN,Anzu,0,0,0,,雷
Dialogue: 0,0:12:26.30,0:12:28.02,CN,Nozomi,0,0,0,,嗯 你也見過吧
Dialogue: 0,0:12:28.02,0:12:32.25,CN,Nozomi,0,0,0,,之前那種一閃一閃的光突然轟隆地落下來
Dialogue: 0,0:12:32.25,0:12:35.98,CN,Anzu,0,0,0,,我知道 別看我小就小看我
Dialogue: 0,0:12:36.62,0:12:38.32,CN,Nozomi,0,0,0,,抱歉 抱歉
Dialogue: 0,0:12:41.05,0:12:44.73,CN,Natsume,0,0,0,,這樣啊 果然是雷呢
Dialogue: 0,0:12:44.73,0:12:48.46,CN,Nanase,0,0,0,,是的 我們來到這裡的時候也一模一樣
Dialogue: 0,0:12:48.46,0:12:52.11,CN,Natsume,0,0,0,,要是明白雷的什麼東西與時間移動有關聯
Dialogue: 0,0:12:52.11,0:12:56.35,CN,Natsume,0,0,0,,或許不等打雷 就能找到回去的辦法了
Dialogue: 0,0:13:00.10,0:13:02.09,CN,Anzu,0,0,0,,要回去了嗎
Dialogue: 0,0:13:02.94,0:13:08.70,CN,Anzu,0,0,0,,之後雷電到來 希和大家就要回到未來了
Dialogue: 0,0:13:11.75,0:13:17.11,CN,Nanase,0,0,0,,我一直都在想 是不是不回去也可以
Dialogue: 0,0:13:17.11,0:13:18.02,CN,Natsume,0,0,0,,欸
Dialogue: 0,0:13:18.02,0:13:20.32,CN,Nanase,0,0,0,,我自從上了高中
Dialogue: 0,0:13:20.32,0:13:23.72,CN,Nanase,0,0,0,,和她們相遇前 真的就是空氣
Dialogue: 0,0:13:23.72,0:13:26.57,CN,Nanase,0,0,0,,休息時間 也沉浸在圖書館裡
Dialogue: 0,0:13:26.57,0:13:29.53,CN,Nanase,0,0,0,,手邊抓起書 就是拚命地讀
Dialogue: 0,0:13:29.98,0:13:34.25,CN,Nanase,0,0,0,,那個時候 毫無目的積累的知識
Dialogue: 0,0:13:34.25,0:13:36.15,CN,Nanase,0,0,0,,第一次這麼「有用」
Dialogue: 0,0:13:36.75,0:13:37.93,CN,Natsume,0,0,0,,第一次
Dialogue: 0,0:13:39.17,0:13:41.95,CN,Nanase,0,0,0,,我們的世界是不需要知識也能生存的時代
Dialogue: 0,0:13:41.95,0:13:43.92,CN,Nanase,0,0,0,,有電腦有手機
Dialogue: 0,0:13:43.92,0:13:46.85,CN,Nanase,0,0,0,,還有能一瞬間就能查到答案的機器
Dialogue: 0,0:13:47.98,0:13:50.38,CN,Natsume,0,0,0,,一瞬間查到答案的機器
Dialogue: 0,0:13:51.10,0:13:55.06,CN,Nanase,0,0,0,,這是我第一次 第一次這麼覺得
Dialogue: 0,0:13:55.06,0:13:57.87,CN,Nanase,0,0,0,,我是多麼有「存在感」啊
Dialogue: 0,0:14:00.82,0:14:04.57,CN,Nanase,0,0,0,,你不用擔心 我明白的 我會回去的
Dialogue: 0,0:14:04.57,0:14:07.62,CN,Nanase,0,0,0,,我要把她們好好地帶回去
Dialogue: 0,0:14:09.75,0:14:14.83,CN,Natsume,0,0,0,,我可沒有擔心你哦 只是有點想挽留你了
Dialogue: 0,0:14:17.67,0:14:21.42,CN,Nanase,0,0,0,,說起來 在天空降下光團的時候
Dialogue: 0,0:14:21.42,0:14:23.49,CN,Nanase,0,0,0,,你們都在做什麼呢
Dialogue: 0,0:14:24.02,0:14:24.81,CN,Natsume,0,0,0,,欸
Dialogue: 0,0:14:24.81,0:14:29.09,CN,Nanase,0,0,0,,我覺得這會不會隱藏著什麼線索
Dialogue: 0,0:14:29.09,0:14:30.64,CN,Natsume,0,0,0,,在玩保齡球
Dialogue: 0,0:14:30.64,0:14:31.34,CN,Nanase,0,0,0,,欸
Dialogue: 0,0:14:31.61,0:14:34.19,CN,Natsume,0,0,0,,你知道嗎 很快樂的
Dialogue: 0,0:14:34.19,0:14:37.35,CN,Natsume,0,0,0,,把樹枝排好 再用球滾過去把它們擊倒
Dialogue: 0,0:14:37.64,0:14:39.69,CN,Natsume,0,0,0,,是那個人教我的呢
Dialogue: 0,0:14:39.69,0:14:42.54,CN,Natsume,0,0,0,,說是以前經常和孩子們玩呢
Dialogue: 0,0:14:47.07,0:14:48.18,CN,Mai,0,0,0,,利奈
Dialogue: 0,0:14:52.97,0:14:55.53,CN,Mai,0,0,0,,啊 對 對不起 我擅自來玩
Dialogue: 0,0:14:55.53,0:14:59.09,CN,Mai,0,0,0,,村民們正在用神社的保齡球場
Dialogue: 0,0:14:59.62,0:15:02.66,CN,Rina,0,0,0,,沒事 這也不是獨屬於我的場所
Dialogue: 0,0:15:03.37,0:15:07.63,CN,Mai,0,0,0,,這樣啊 是利奈你為大家製作的吧
Dialogue: 0,0:15:09.67,0:15:10.70,CN,Rina,0,0,0,,不是
Dialogue: 0,0:15:21.69,0:15:24.40,CN,Nanase,0,0,0,,怎麼可能 太巧合了吧
Dialogue: 0,0:15:24.40,0:15:25.65,CN,Nozomi,0,0,0,,什麼巧合
Dialogue: 0,0:15:25.65,0:15:27.38,CN,Nanase,0,0,0,,我 我在自言自語
Dialogue: 0,0:15:28.22,0:15:30.77,CN,Nanase,0,0,0,,雷還是沒有打啊
Dialogue: 0,0:15:30.77,0:15:32.84,CN,Nozomi,0,0,0,,吶 七瀨
Dialogue: 0,0:15:32.84,0:15:33.87,CN,Nanase,0,0,0,,怎麼了
Dialogue: 0,0:15:34.21,0:15:36.66,CN,Nozomi,0,0,0,,我們非得回去不可嗎
Dialogue: 0,0:15:38.30,0:15:40.41,CN,Nanase,0,0,0,,這話 你適合說嗎
Dialogue: 0,0:15:44.43,0:15:47.67,CN,Mai,0,0,0,,啊 好開心 謝謝你 利奈
Dialogue: 0,0:15:48.91,0:15:50.49,CN,Rina,0,0,0,,是有關係嗎
Dialogue: 0,0:15:50.49,0:15:51.42,CN,Mai,0,0,0,,欸
Dialogue: 0,0:15:51.42,0:15:55.01,CN,Rina,0,0,0,,部長比賽無法勝利 和你父母的事情有關
Dialogue: 0,0:15:56.43,0:15:58.39,CN,Rina,0,0,0,,我從小百合那聽到的
Dialogue: 0,0:15:58.39,0:16:01.94,CN,Rina,0,0,0,,若這是你不想讓我知道的 我向你道歉
Dialogue: 0,0:16:02.44,0:16:05.44,CN,Mai,0,0,0,,沒有 我完全不會這麼做
Dialogue: 0,0:16:05.44,0:16:08.96,CN,Mai,0,0,0,,我完全不會對利奈你隱瞞什麼的
Dialogue: 0,0:16:08.96,0:16:11.34,CN,Mai,0,0,0,,就是那種話題 太陰沉了
Dialogue: 0,0:16:11.34,0:16:12.56,CN,Rina,0,0,0,,一點也不
Dialogue: 0,0:16:12.56,0:16:13.46,CN,Mai,0,0,0,,欸
Dialogue: 0,0:16:13.46,0:16:15.34,CN,Rina,0,0,0,,這不是沉重的話題
Dialogue: 0,0:16:15.75,0:16:18.45,CN,Rina,0,0,0,,這是部長你 堅強努力的過去
Dialogue: 0,0:16:21.21,0:16:22.46,CN,Mai,0,0,0,,謝謝
Dialogue: 0,0:16:31.87,0:16:34.72,CN,Mai,0,0,0,,說實話 我也不明白
Dialogue: 0,0:16:34.72,0:16:39.21,CN,Mai,0,0,0,,從那時開始就贏不了 我也在想是不是有關係
Dialogue: 0,0:16:39.62,0:16:44.19,CN,Mai,0,0,0,,但是我也不明白自己 到底為什麼會這樣
Dialogue: 0,0:16:44.62,0:16:45.72,CN,Rina,0,0,0,,三連全中
Dialogue: 0,0:16:45.72,0:16:46.34,CN,Mai,0,0,0,,欸
Dialogue: 0,0:16:46.34,0:16:48.39,CN,Rina,0,0,0,,一打出三連就變得奇怪了
Dialogue: 0,0:16:49.19,0:16:51.09,CN,Mai,0,0,0,,嗯 什麼奇怪
Dialogue: 0,0:16:51.09,0:16:52.21,CN,Rina,0,0,0,,部長你奇怪
Dialogue: 0,0:16:52.21,0:16:53.24,CN,Mai,0,0,0,,我嗎
Dialogue: 0,0:16:53.24,0:16:55.28,CN,Rina,0,0,0,,狀態一直都「絕好調」
Dialogue: 0,0:16:56.25,0:16:59.24,CN,Rina,0,0,0,,從第四球開始就變得不行了
Dialogue: 0,0:16:59.24,0:17:00.62,CN,Mai,0,0,0,,確實
Dialogue: 0,0:17:01.77,0:17:05.37,CN,Rina,0,0,0,,對不起 我以為你是故意輸的
Dialogue: 0,0:17:06.21,0:17:08.71,CN,Mai,0,0,0,,沒關係 我也很抱歉
Dialogue: 0,0:17:09.70,0:17:12.37,CN,Mai,0,0,0,,我一直都沒有明白利奈你的情感
Dialogue: 0,0:17:13.65,0:17:15.71,CN,Mai,0,0,0,,我會好好想的
Dialogue: 0,0:17:16.61,0:17:18.70,CN,Mai,0,0,0,,不讓利奈一個人孤單的辦法
Dialogue: 0,0:17:19.10,0:17:20.66,CN,Rina,0,0,0,,我也會好好想的
Dialogue: 0,0:17:22.18,0:17:23.26,CN,Rina,0,0,0,,讓部長
Dialogue: 0,0:17:25.15,0:17:27.52,CN,Rina,0,0,0,,和部長一起獲勝的辦法
Dialogue: 0,0:17:29.13,0:17:30.27,CN,Mai,0,0,0,,謝謝你
Dialogue: 0,0:17:31.07,0:17:33.25,CN,Rina,0,0,0,,在那之前要先回去呢
Dialogue: 0,0:17:38.78,0:17:39.70,CN,Mai,0,0,0,,是呀
Dialogue: 0,0:17:58.31,0:17:59.30,CN,Mai,0,0,0,,保齡球
Dialogue: 0,0:17:59.67,0:18:01.41,CN,Nozomi,0,0,0,,怎麼了
Dialogue: 0,0:18:01.41,0:18:03.82,CN,Mai,0,0,0,,吶 剛剛是不是有保齡球的聲音
Dialogue: 0,0:18:03.82,0:18:05.53,CN,Sayuri,0,0,0,,保齡球的聲音
Dialogue: 0,0:18:05.53,0:18:08.77,CN,Nanase,0,0,0,,有保齡球的聲音又怎麼了啊
Dialogue: 0,0:18:09.31,0:18:11.45,CN,Mai,0,0,0,,吶 吶 聽到了吧
Dialogue: 0,0:18:11.45,0:18:12.88,CN,Sayuri,0,0,0,,聽到了
Dialogue: 0,0:18:12.88,0:18:14.46,CN,Mai,0,0,0,,是誰在玩呢
Dialogue: 0,0:18:14.46,0:18:16.07,CN,Nanase,0,0,0,,不對不對不對
Dialogue: 0,0:18:16.07,0:18:17.12,CN,Nozomi,0,0,0,,不可能吧
Dialogue: 0,0:18:17.12,0:18:20.41,CN,Nanase,0,0,0,,誰會在深夜裡玩保齡球啊
Dialogue: 0,0:18:20.82,0:18:23.67,CN,Sayuri,0,0,0,,欸 那麼 這個聲音是
Dialogue: 0,0:18:24.08,0:18:24.97,CN,Rina,0,0,0,,小偷
Dialogue: 0,0:18:27.75,0:18:30.83,CN,Sayuri,0,0,0,,果然 叫傑里大人過來更好吧
Dialogue: 0,0:18:31.10,0:18:34.06,CN,Nanase,0,0,0,,說起來 為什麼要我打頭陣啊
Dialogue: 0,0:18:34.06,0:18:36.58,CN,Nozomi,0,0,0,,你是我們中最矮的啊
Dialogue: 0,0:18:36.58,0:18:37.71,CN,Nanase,0,0,0,,身高升序嗎
Dialogue: 0,0:18:38.59,0:18:40.67,CN,Nozomi,0,0,0,,哈 為什麼要拿著保齡球
Dialogue: 0,0:18:40.67,0:18:43.22,CN,Mai,0,0,0,,欸 玩保齡球當然要參加啊
Dialogue: 0,0:18:43.22,0:18:46.96,CN,Nozomi,0,0,0,,你們到底是保齡球的什麼 僕人嗎
Dialogue: 0,0:18:46.96,0:18:47.98,CN,Rina,0,0,0,,僕人
Dialogue: 0,0:18:49.23,0:18:52.77,CN,Nanase,0,0,0,,感覺越來越近了 聲音
Dialogue: 0,0:18:55.29,0:18:56.85,CN,Nanase,0,0,0,,死路走不通了
Dialogue: 0,0:18:56.85,0:18:58.35,CN,Mai,0,0,0,,欸 怎麼回事
Dialogue: 0,0:18:59.47,0:19:02.22,CN,Sayuri,0,0,0,,是是是 是牆壁裡面
Dialogue: 0,0:19:02.22,0:19:05.53,CN,Nozomi,0,0,0,,欸 什麼鬼 什麼類別 恐怖類嗎
Dialogue: 0,0:19:05.53,0:19:07.27,CN,Mai,0,0,0,,到底是那個類別啊
Dialogue: 0,0:19:07.27,0:19:09.30,CN,Mai,0,0,0,,僵屍類 血腥類
Dialogue: 0,0:19:09.30,0:19:12.57,CN,Nozomi,0,0,0,,恐怖類不是說過了嗎 還有靈異類
Dialogue: 0,0:19:12.57,0:19:16.75,CN,Mai,0,0,0,,靈 靈異類 貞子 伽椰子 麥可 是哪個
Dialogue: 0,0:19:17.47,0:19:20.03,CN,Nozomi,0,0,0,,就是有過「案件」的那種
Dialogue: 0,0:19:46.43,0:19:47.54,CN,Nozomi,0,0,0,,好恐怖
Dialogue: 0,0:19:48.93,0:19:49.77,CN,Mai,0,0,0,,走吧
Dialogue: 0,0:19:49.77,0:19:50.79,CN,Sayuri,0,0,0,,欸
Dialogue: 0,0:19:50.79,0:19:52.43,CN,Nozomi,0,0,0,,不要不要不要
Dialogue: 0,0:19:52.52,0:19:54.79,CN,Sayuri,0,0,0,,不走最好吧
Dialogue: 0,0:19:54.79,0:19:58.02,CN,Mai,0,0,0,,利奈的背包 要去取回來
Dialogue: 0,0:20:01.85,0:20:03.81,CN,Nozomi,0,0,0,,喂 你別推我啊
Dialogue: 0,0:20:03.81,0:20:07.21,CN,Rina,0,0,0,,我沒推你 是你走得太慢被堵住了
Dialogue: 0,0:20:11.75,0:20:12.75,CN,Nozomi,0,0,0,,恐怖
Dialogue: 0,0:20:12.75,0:20:14.06,CN,Sayuri,0,0,0,,地下室
Dialogue: 0,0:20:15.02,0:20:16.15,CN,Nanase,0,0,0,,回去吧
Dialogue: 0,0:20:16.15,0:20:16.85,CN,Mai,0,0,0,,欸
Dialogue: 0,0:20:16.85,0:20:20.39,CN,Nanase,0,0,0,,這裡肯定是真正不能踏足的場所
Dialogue: 0,0:20:20.75,0:20:23.01,CN,Nanase,0,0,0,,麻衣姐 早點把保齡球回收好吧
Dialogue: 0,0:20:23.77,0:20:25.59,CN,Mai,0,0,0,,啊 好
Dialogue: 0,0:20:43.59,0:20:44.49,CN,Akebi,0,0,0,,是誰
Dialogue: 0,0:20:51.06,0:20:52.85,CN,Mai,0,0,0,,壽桃
Dialogue: 0,0:20:52.85,0:20:53.90,CN,Sumomo,0,0,0,,麻衣
Dialogue: 0,0:20:54.85,0:20:55.85,CN,Mai,0,0,0,,欸
Dialogue: 0,0:20:56.85,0:20:57.83,CN,Nanase,0,0,0,,果然
Dialogue: 0,0:20:57.83,0:20:58.46,CN,Nozomi,0,0,0,,欸
Dialogue: 0,0:20:58.46,0:21:00.82,CN,Suguri,0,0,0,,你們終於發現了
Dialogue: 0,0:21:12.25,0:21:13.42,CN,Suguri,0,0,0,,這個家的
Dialogue: 0,0:21:15.31,0:21:16.67,CN,Suguri,0,0,0,,秘密
